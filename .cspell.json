{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules/**",
    "**/node_modules/**",
    "packages/**",
    "**/packages/**",
    "vendor/**",
    "**/vendor/**",
    "dist/**",
    "build/**",
    ".git/**",
    "**/.terraform/**",
    "**/.terraform.lock.hcl",
    ".vscode/**",
    ".github/copilot-instructions.md",
